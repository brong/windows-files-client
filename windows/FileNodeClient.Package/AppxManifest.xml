<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap4="http://schemas.microsoft.com/appx/manifest/uap/windows10/4"
  xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:desktop3="http://schemas.microsoft.com/appx/manifest/desktop/windows10/3"
  xmlns:desktop4="http://schemas.microsoft.com/appx/manifest/desktop/windows10/4"
  xmlns:desktop7="http://schemas.microsoft.com/appx/manifest/desktop/windows10/7"
  xmlns:desktop8="http://schemas.microsoft.com/appx/manifest/desktop/windows10/8"
  xmlns:cloudFiles="http://schemas.microsoft.com/appx/manifest/cloudstorage/windows10"
  IgnorableNamespaces="uap uap4 desktop desktop3 desktop4 desktop7 desktop8 rescap com cloudFiles">

  <Identity
    Name="Fastmail.FileNodeClient"
    Publisher="CN=Fastmail Pty Ltd"
    Version="1.0.2.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>FileNodeClient</DisplayName>
    <PublisherDisplayName>Fastmail Pty Ltd</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.22621.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="App"
      Executable="FileNodeClient.App.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="FileNodeClient"
        Description="Fastmail file sync for Windows"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
      <Extensions>
        <!-- Auto-start App at login -->
        <desktop:Extension Category="windows.startupTask" Executable="FileNodeClient.App.exe" EntryPoint="Windows.FullTrustApplication">
          <desktop:StartupTask TaskId="FileNodeClientStartup" Enabled="true" DisplayName="FileNodeClient" />
        </desktop:Extension>

      </Extensions>
    </Application>

    <Application Id="Service"
      Executable="FileNodeClient.Service.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="FileNodeClient Service"
        Description="Fastmail file sync background service"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png"
        AppListEntry="none" />
      <Extensions>
        <!-- Auto-start Service at login -->
        <desktop:Extension Category="windows.startupTask" Executable="FileNodeClient.Service.exe" EntryPoint="Windows.FullTrustApplication">
          <desktop:StartupTask TaskId="FileNodeClientServiceStartup" Enabled="true" DisplayName="FileNodeClient Service" />
        </desktop:Extension>

        <!-- Cloud files handler registration -->
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:ExeServer Executable="FileNodeClient.Service.exe" DisplayName="FileNodeClient Handlers">
              <com:Class Id="A7B3E2D1-9F4C-4A8B-B5E6-1D3C7F8A2E9B" DisplayName="FileNodeClient UriSource" />
            </com:ExeServer>
            <com:SurrogateServer DisplayName="FileNodeClient ThumbnailProvider">
              <com:Class Id="B8C4F3E2-1A5D-4B9C-C6F7-2E4D8A9B3F1C"
                         Path="FileNodeClient.ThumbnailExtension.dll"
                         ThreadingModel="Both" />
            </com:SurrogateServer>
          </com:ComServer>
        </com:Extension>

        <desktop3:Extension Category="windows.cloudFiles">
          <desktop3:CloudFiles>
            <!-- Dummy CLSIDs for required-but-unimplemented handlers (not registered, COM returns REGDB_E_CLASSNOTREG) -->
            <desktop3:CustomStateHandler Clsid="00000000-0000-0000-0000-000000000001" />
            <desktop3:ThumbnailProviderHandler Clsid="B8C4F3E2-1A5D-4B9C-C6F7-2E4D8A9B3F1C" />
            <desktop3:ExtendedPropertyHandler Clsid="00000000-0000-0000-0000-000000000002" />
            <desktop3:BannersHandler Clsid="00000000-0000-0000-0000-000000000003" />
            <desktop3:CloudFilesContextMenus />
            <desktop4:ContentUriSource Clsid="A7B3E2D1-9F4C-4A8B-B5E6-1D3C7F8A2E9B" />
          </desktop3:CloudFiles>
        </desktop3:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <uap4:CustomCapability Name="Microsoft.classicAppCompat_8wekyb3d8bbwe" />
    <uap4:CustomCapability Name="Microsoft.classicAppCompatElevated_8wekyb3d8bbwe" />
  </Capabilities>

  <Extensions>
    <!-- ETW providers: events appear in Event Viewer under
         Applications and Services Logs > Fastmail-FileNodeClient-Service/App > Operational -->
    <desktop8:Extension Category="windows.eventTracing"
                        desktop7:Scope="machine"
                        desktop7:CompatMode="classic">
      <desktop8:EventTracing>
        <desktop8:Provider Id="584b95ba-9994-512f-a63a-bb0e7100084b"
                           Name="Fastmail-FileNodeClient-Service"
                           ResourceFile="FileNodeClient.EventLog.dll"
                           MessageFile="FileNodeClient.EventLog.dll">
          <desktop8:Channels>
            <desktop8:Channel Name="Fastmail-FileNodeClient-Service/Operational"
                              Type="operational"
                              Enabled="true" />
          </desktop8:Channels>
        </desktop8:Provider>
        <desktop8:Provider Id="d0379af1-950b-5d91-afba-b6c91473c5b2"
                           Name="Fastmail-FileNodeClient-App"
                           ResourceFile="FileNodeClient.EventLog.dll"
                           MessageFile="FileNodeClient.EventLog.dll">
          <desktop8:Channels>
            <desktop8:Channel Name="Fastmail-FileNodeClient-App/Operational"
                              Type="operational"
                              Enabled="true" />
          </desktop8:Channels>
        </desktop8:Provider>
      </desktop8:EventTracing>
    </desktop8:Extension>
  </Extensions>
</Package>
